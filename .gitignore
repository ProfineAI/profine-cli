# profine
.profine/
.profine_tmp/
.profine_optimized_*.py
profine_output*/
# Exception: the canonical demo artifacts in examples/minGPT/ ARE checked in
# as evidence the headline numbers in the README are reproducible.
!examples/minGPT/profine_output/
!examples/minGPT/profine_output/**
quickstart_out/

# profine-output _debug dumps (per-run, not for the repo)
examples/**/profine_output/_debug/
examples/**/run.log

# Local experiment runs — `profine run-all --output runs/<name>` lands here
runs/

# Auth + telemetry consent live in the user's home, but never commit
# copies that get dragged into the tree
auth.json
telemetry_consent.json

# Tokenized datasets generated by each example's data/<name>/prepare.py
# (input text, .bin/.npy/.arrow/.parquet, pickle metadata) — re-buildable,
# not source.
examples/**/data/*/input.txt
examples/**/data/*/*.bin
examples/**/data/*/*.npy
examples/**/data/*/*.arrow
examples/**/data/*/*.parquet
examples/**/data/*/meta.pkl
